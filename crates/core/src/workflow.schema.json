{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boson.local/schemas/workflow.schema.json",
  "title": "Boson Workflow Definition",
  "type": "object",
  "required": ["id", "name", "steps"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["route_id"],
        "properties": {
          "name": { "type": "string" },
          "route_id": { "type": "string", "minLength": 1 },
          "vars": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "value"],
              "properties": {
                "key": { "type": "string" },
                "value": { "type": "string" },
                "enabled": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          },
          "extract": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "path"],
              "properties": {
                "key": { "type": "string" },
                "path": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
